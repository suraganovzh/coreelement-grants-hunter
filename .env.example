# ===========================================
# Grant Hunter AI - Environment Configuration
# ===========================================
# Copy to .env and fill in values. NEVER commit .env
#
# LLM cascade: Ollama (local) -> Groq (free) -> Gemini (free) -> rules

# --- Telegram Bot (get from @BotFather) ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# --- LLM Cascade (all free tiers) ---
# Level 1: Ollama — runs locally, no key needed (install: https://ollama.ai)
# Level 2: Groq — free tier, get key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
# Level 3: Gemini — free tier, get key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- Data Sources ---
# SAM.gov — get key at https://sam.gov/content/entity-information
SAM_GOV_API_KEY=your_sam_gov_api_key_here

# --- General ---
LOG_LEVEL=INFO
