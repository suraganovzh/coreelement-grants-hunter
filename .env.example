# ===========================================
# Grant Hunter AI - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file to version control

# --- AI API Keys ---
GROQ_API_KEY=gsk_your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# --- Database ---
# For SQLite (MVP):
DATABASE_URL=sqlite:///data/grants_hunter.db
# For PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/grant_hunter

# --- Grants.gov API ---
GRANTS_GOV_API_KEY=your_grants_gov_api_key_here

# --- Optional: Logging ---
LOG_LEVEL=INFO

# --- Optional: VPS Deployment ---
VPS_HOST=your_vps_ip
VPS_USER=deploy
VPS_SSH_KEY_PATH=~/.ssh/id_rsa
